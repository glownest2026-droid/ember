# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public site URL (Vercel Production only). OAuth/magic-link callbacks use
# https://<this>/auth/callback. Omit locally — localhost always uses the browser origin.
# Example production: https://emberplay.app
# Production only (Vercel Production env). Browser OAuth uses current origin; do not set on Preview to force production callback.
NEXT_PUBLIC_SITE_URL=

# Builder.io CMS Configuration
NEXT_PUBLIC_BUILDER_API_KEY=

# Builder.io Preview Secret (for draft content preview)
# Set this in Vercel env vars - rotate if leaked
BUILDER_PREVIEW_SECRET=
