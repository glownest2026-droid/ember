# Server-only Gemini (marketplace listing AI — PR3/PR4)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
# Image analysis (PR3). Default 5; use 100 on Vercel Preview for founder testing.
AI_LISTING_DAILY_LIMIT=5
AI_LISTING_DETAILS_DAILY_LIMIT=10

# Public Mapbox token for marketplace map (browser). Leave empty to use fallback visual.
NEXT_PUBLIC_MAPBOX_TOKEN=
